generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── CORE (Phase 1) ──────────────────────────────────────────────────────────

model Organization {
  id                      String    @id @default(cuid())
  clerkOrgId              String    @unique
  name                    String
  slug                    String?   @unique
  squareCustomerId        String?
  squareSubscriptionId    String?
  subscriptionStatus      String?   @default("inactive")
  activeModules           String[]  @default([])
  squareAccessToken       String?
  squareRefreshToken      String?
  squareTokenExpiresAt    DateTime?
  lastCatalogSyncAt       DateTime?
  instagramAccessToken    String?
  instagramTokenExpiresAt DateTime?
  instagramUserId         String?
  instagramUsername       String?
  instagramEnabled        Boolean   @default(false)
  instagramConnectedAt    DateTime?
  // Days an unacknowledged handoff note keeps surfacing past its target day.
  handoffNoteExpireDays   Int       @default(2)
  createdAt               DateTime  @default(now())

  stores                        Store[]
  users                         User[]
  pendingInvites                PendingInvite[]
  staff                         StaffMember[]
  templates                     Template[]
  checklists                    Checklist[]
  storageAreas                  StorageArea[]
  inventoryCounts               InventoryCount[]
  itemMetadata                  ItemMetadata[]
  menuItems                     MenuItem[]
  auditLogs                     AuditLog[]
  catalogCategories             CatalogCategory[]
  catalogItems                  CatalogItem[]
  vendors                       Vendor[]
  purchaseOrders                PurchaseOrder[]
  squareCategories              SquareCategory[]
  salesItems                    SalesItem[]
  ingredientCategories          IngredientCategory[]
  ingredients                   Ingredient[]
  ingredientDuplicateDismissals IngredientDuplicateDismissal[]
  salesPeriodCaches             SalesPeriodCache[]
  salesLineCaches               SalesLineCache[]
  salesHourlyCaches             SalesHourlyCache[]
  storeMonthlyGoals             StoreMonthlyGoal[]
  goalPlans                     GoalPlan[]
  recipes                       Recipe[]
  inventoryAdjustments          InventoryAdjustment[]
  adjustmentGroups              AdjustmentGroup[]
  lossReasons                   LossReason[]
  varianceAdjustments           VarianceAdjustment[]
  storeIngredientPars           StoreIngredientPar[]
  teamMessages                  TeamMessage[]
  corporateUpdates              CorporateUpdate[]
  paceAlertLogs                 PaceAlertLog[]
  hrDocuments                   HrDocument[]
  managerNotes                  ManagerNote[]
  trainingModules               TrainingModule[]
}

model User {
  id             String   @id @default(cuid())
  clerkUserId    String   @unique
  organizationId String
  email          String
  name           String?
  role           Role     @default(STAFF)
  createdAt      DateTime @default(now())

  organization         Organization          @relation(fields: [organizationId], references: [id])
  storeAssignments     StoreUserAssignment[]
  taskLogs             TaskLog[]
  teamMessages         TeamMessage[]         @relation("TeamMessageAuthor")
  resolvedMessages     TeamMessage[]         @relation("TeamMessageResolver")
  acknowledgedMessages TeamMessage[]         @relation("TeamMessageAcknowledger")
  messageReactions     MessageReaction[]
  messageReads         MessageRead[]
  corporateUpdates     CorporateUpdate[]
}

model Store {
  id               String   @id @default(cuid())
  organizationId   String
  squareLocationId String?  @unique
  storeNumber      String?
  name             String
  brand            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  timezone         String   @default("America/Los_Angeles")
  contactEmail     String?
  phoneNumber      String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  organization              Organization                    @relation(fields: [organizationId], references: [id])
  hours                     StoreHours[]
  userAssignments           StoreUserAssignment[]
  staffAssignments          StoreStaffAssignment[]
  templateAssignments       TemplateStoreAssignment[]
  checklists                Checklist[]
  storageAreas              StorageArea[]
  inventoryCounts           InventoryCount[]
  purchaseOrders            PurchaseOrder[]
  salesPeriodCaches         SalesPeriodCache[]
  salesLineCaches           SalesLineCache[]
  salesHourlyCaches         SalesHourlyCache[]
  monthlyGoals              StoreMonthlyGoal[]
  goalPlans                 GoalPlan[]
  dailyGoals                DailyGoal[]
  inventoryAdjustments      InventoryAdjustment[]
  adjustmentGroupsFrom      AdjustmentGroup[]               @relation("AdjustmentGroupFromStore")
  adjustmentGroupsTo        AdjustmentGroup[]               @relation("AdjustmentGroupToStore")
  varianceAdjustments       VarianceAdjustment[]
  ingredientPars            StoreIngredientPar[]
  teamMessages              TeamMessage[]
  paceAlertLogs             PaceAlertLog[]
  hrDocumentAssignments     HrDocumentStoreAssignment[]
  trainingModuleAssignments TrainingModuleStoreAssignment[]
}

model StoreHours {
  id          String  @id @default(cuid())
  storeId     String
  dayOfWeek   Int
  openingTime String?
  closingTime String?
  isClosed    Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreUserAssignment {
  id      String @id @default(cuid())
  userId  String
  storeId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model PendingInvite {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           Role
  storeIds       String[] @default([])
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
}

model StaffMember {
  id                 String   @id @default(cuid())
  organizationId     String
  squareTeamMemberId String?  @unique
  displayName        String
  fullName           String?
  email              String?
  createdAt          DateTime @default(now())

  organization        Organization             @relation(fields: [organizationId], references: [id])
  storeAssignments    StoreStaffAssignment[]
  taskLogs            TaskLog[]
  teamMessages        TeamMessage[]
  managerNotes        ManagerNote[]
  formSubmissions     FormSubmission[]
  trainingAssignments TrainingAssignment[]
  lessonCompletions   TrainingLessonProgress[]
  signedRecords       HrSignedRecord[]
}

model StoreStaffAssignment {
  id            String  @id @default(cuid())
  staffMemberId String
  storeId       String
  isPrimary     Boolean @default(false)

  staffMember StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([staffMemberId, storeId])
}

model Template {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  type             String
  frequency        String   @default("Daily")
  availabilityType String   @default("StoreHours")
  operationalPhase String?
  startOffsetHours Int?
  endOffsetHours   Int?
  isActive         Boolean  @default(true)
  isArchived       Boolean  @default(false)
  appliesTo        String   @default("all")
  createdAt        DateTime @default(now())

  organization     Organization              @relation(fields: [organizationId], references: [id])
  storeAssignments TemplateStoreAssignment[]
  tasks            Task[]
  checklists       Checklist[]
  handoffMessages  TeamMessage[]             @relation("HandoffTarget")
}

model TemplateStoreAssignment {
  id         String @id @default(cuid())
  templateId String
  storeId    String

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([templateId, storeId])
}

model Task {
  id                   String   @id @default(cuid())
  templateId           String
  sectionName          String
  description          String
  estimatedTimeMinutes Float?
  requiresPhoto        Boolean  @default(false)
  requiresTemp         Boolean  @default(false)
  isCritical           Boolean  @default(false)
  orderIndex           Int      @default(0)
  excludedStoreIds     String[]
  videoUrl             String?

  template   Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  taskLogs   TaskLog[]
  attachment TaskAttachment?
}

model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String   @unique
  label       String
  url         String
  contentType String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Checklist {
  id             String    @id @default(cuid())
  organizationId String
  templateId     String
  storeId        String
  date           DateTime
  status         String    @default("Pending")
  startedAt      DateTime?
  completedAt    DateTime?
  completionRate Float?    @default(0)

  organization    Organization  @relation(fields: [organizationId], references: [id])
  template        Template      @relation(fields: [templateId], references: [id])
  store           Store         @relation(fields: [storeId], references: [id])
  taskLogs        TaskLog[]
  handoffMessages TeamMessage[] @relation("HandoffSource")
}

model TaskLog {
  id                 String   @id @default(cuid())
  checklistId        String
  taskId             String
  completedByUserId  String?
  completedByStaffId String?
  completedAt        DateTime @default(now())
  photoUrl           String?
  temperatureValue   Float?
  notes              String?

  checklist        Checklist    @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  task             Task         @relation(fields: [taskId], references: [id])
  completedByUser  User?        @relation(fields: [completedByUserId], references: [id])
  completedByStaff StaffMember? @relation(fields: [completedByStaffId], references: [id])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, entityType, createdAt])
}

// ─── PHASE F-5: BEHIND-PACE ALERTS ───────────────────────────────────────────
// One row per store-month = the alert was sent; its unique constraint is the
// idempotency lock that keeps the daily cron from re-alerting all month.
model PaceAlertLog {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  month          DateTime @db.Date // first-of-month UTC date
  pacePct        Float
  thresholdPct   Float
  recipients     String[]
  sentAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, month])
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  STORE
}

// ─── PHASE 2: INVENTORY MODULE ────────────────────────────────────────────────

model StorageArea {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  name           String
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  organization       Organization               @relation(fields: [organizationId], references: [id])
  store              Store                      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ingredientMappings IngredientStorageMapping[]
  countLines         InventoryCountLine[]
}

// Per-store assignment of an ingredient to a storage area. An ingredient may map
// into multiple areas of the same store; sortOrder is the shelf-to-sheet count order.
model IngredientStorageMapping {
  id            String @id @default(cuid())
  storageAreaId String
  ingredientId  String
  sortOrder     Int    @default(0)

  storageArea StorageArea @relation(fields: [storageAreaId], references: [id], onDelete: Cascade)
  ingredient  Ingredient  @relation(fields: [ingredientId], references: [id])

  @@unique([storageAreaId, ingredientId])
}

model ItemMetadata {
  id                 String   @id @default(cuid())
  organizationId     String
  squareCatalogObjId String
  vendorName         String?
  vendorId           String?
  glCode             String?
  parLevel           Float?
  unitCostOverride   Float?
  unitOfMeasure      String?
  notes              String?
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])

  @@unique([organizationId, squareCatalogObjId])
}

model CatalogCategory {
  id               String  @id @default(cuid())
  organizationId   String
  squareCategoryId String
  name             String
  isDeleted        Boolean @default(false)
  sortOrder        Int     @default(0)

  organization Organization  @relation(fields: [organizationId], references: [id])
  items        CatalogItem[]

  @@unique([organizationId, squareCategoryId])
}

model CatalogItem {
  id             String   @id @default(cuid())
  organizationId String
  squareItemId   String?
  categoryId     String?
  name           String
  description    String?
  isDeleted      Boolean  @default(false)
  isArchived     Boolean  @default(false)
  productType    String?
  updatedAt      DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id])
  category     CatalogCategory?       @relation(fields: [categoryId], references: [id])
  variations   CatalogItemVariation[]

  @@unique([organizationId, squareItemId])
}

model CatalogItemVariation {
  id                String  @id @default(cuid())
  catalogItemId     String
  squareVariationId String?
  name              String
  sku               String?
  priceMoney        Int?
  ordinal           Int     @default(0)

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([catalogItemId, squareVariationId])
}

model Vendor {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  accountNumber   String?
  contactName     String?
  email           String?
  phone           String?
  terms           String?
  leadTimeDays    Int?
  // I-7: minimum-order thresholds — cart review warns (never blocks) when a
  // draft PO for this vendor is under either one.
  minOrderCases   Float?
  minOrderDollars Float?
  // I-7: weekday ints 0 (Sun) – 6 (Sat); new POs default expectedAt to the
  // next configured delivery day (falling back to leadTimeDays, then next
  // weekday).
  deliveryDays    Json?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  organization      Organization       @relation(fields: [organizationId], references: [id])
  vendorIngredients VendorIngredient[]
  purchaseOrders    PurchaseOrder[]
  itemMetadata      ItemMetadata[]
  adjustments       VendorAdjustment[]
}

// I-7: standing invoice-level adjustments (fuel surcharge, bottle deposits,
// credits...) auto-attached as editable lines when receiving this vendor's
// POs. glCode keeps the whole invoice categorizable for finance.
model VendorAdjustment {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  type      String // FLAT | PERCENT (of the PO's line total)
  value     Float // dollars for FLAT, percent points for PERCENT (5 = 5%)
  glCode    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  vendor        Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  poAdjustments PurchaseOrderAdjustment[]
}

// I-7: adjustment line attached to a specific PO at receive time — a snapshot
// of (or manual addition beyond) the vendor's standing adjustments. amount is
// the resolved dollar effect on this PO; included in COGS GL breakdowns.
model PurchaseOrderAdjustment {
  id                 String   @id @default(cuid())
  purchaseOrderId    String
  vendorAdjustmentId String?
  name               String
  type               String // FLAT | PERCENT
  value              Float
  amount             Float
  glCode             String?
  createdAt          DateTime @default(now())

  purchaseOrder    PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  vendorAdjustment VendorAdjustment? @relation(fields: [vendorAdjustmentId], references: [id])
}

model VendorIngredient {
  id              String  @id @default(cuid())
  vendorId        String
  ingredientId    String
  vendorSku       String?
  packDescription String?
  casePrice       Float?
  unitsPerCase    Float?

  vendor     Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([vendorId, ingredientId])
}

model PurchaseOrder {
  id              String    @id @default(cuid())
  organizationId  String
  storeId         String
  vendorId        String
  poNumber        String
  invoiceNumber   String?
  orderedAt       DateTime?
  expectedAt      DateTime?
  totalAmount     Float     @default(0)
  status          String    @default("DRAFT")
  enteredByUserId String?
  receivedAt      DateTime? // set when the PO reaches RECEIVED (fully received)
  invoiceFileUrl  String? // I-7: invoice photo/PDF attached at receiving (Vercel Blob)
  createdAt       DateTime  @default(now())

  organization Organization              @relation(fields: [organizationId], references: [id])
  store        Store                     @relation(fields: [storeId], references: [id])
  vendor       Vendor                    @relation(fields: [vendorId], references: [id])
  lines        PurchaseOrderLine[]
  adjustments  PurchaseOrderAdjustment[]

  @@unique([organizationId, poNumber])
}

model PurchaseOrderLine {
  id               String    @id @default(cuid())
  purchaseOrderId  String
  ingredientId     String
  ingredientName   String
  quantityOrdered  Float
  quantityReceived Float     @default(0)
  unitCost         Float
  lineTotal        Float
  receivingNote    String?
  receivedAt       DateTime? // last receipt timestamp — places the received value in an inventory period

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])
}

// ─── PHASE 2: INVENTORY MODULE v2 — sales items (Square) vs ingredients (Froot) ──

model SquareCategory {
  id               String  @id @default(cuid())
  organizationId   String
  squareCategoryId String
  name             String
  isDeleted        Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id])
  salesItems   SalesItem[]

  @@unique([organizationId, squareCategoryId])
}

model SalesItem {
  id                String   @id @default(cuid())
  organizationId    String
  squareItemId      String
  squareVariationId String
  name              String
  variationName     String
  displayName       String
  squareCategoryId  String?
  menuGroup         String?
  priceCents        Int?
  isDeleted         Boolean  @default(false)
  recipeStatus      String   @default("UNMAPPED") // UNMAPPED | MAPPED | NON_RECIPE
  updatedAt         DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id])
  squareCategory      SquareCategory?      @relation(fields: [squareCategoryId], references: [id])
  recipe              Recipe?
  varianceAdjustments VarianceAdjustment[]

  @@unique([organizationId, squareVariationId])
}

model IngredientCategory {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  glCode         String?
  sortOrder      Int     @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  ingredients  Ingredient[]

  @@unique([organizationId, name])
}

model Ingredient {
  id                   String    @id @default(cuid())
  organizationId       String
  brand                String?
  name                 String
  categoryId           String?
  subcategory          String?
  sku                  String?
  purchaseUnitLabel    String
  packDescription      String?
  purchaseCost         Float
  reportingUnit        String
  unitsPerPurchase     Float
  costPerReportingUnit Float
  glCodeOverride       String?
  productNote          String?
  isActive             Boolean   @default(true)
  isArchived           Boolean   @default(false)
  deletedAt            DateTime?
  lastEditedByUserId   String?
  kind                 String    @default("PURCHASED") // PURCHASED | PREPARED
  // PREPARED only: the countable sub-recipe this ingredient is produced from.
  preparedFromRecipeId String?   @unique
  // Count-by-weighing container weights, stored in oz (dry). tare = empty
  // container, full = full container (full only needed for volume/count items).
  tareWeightOz         Float?
  fullWeightOz         Float?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization       Organization               @relation(fields: [organizationId], references: [id])
  category           IngredientCategory?        @relation(fields: [categoryId], references: [id])
  preparedFromRecipe Recipe?                    @relation("PreparedIngredient", fields: [preparedFromRecipeId], references: [id])
  vendorIngredients  VendorIngredient[]
  purchaseOrderLines PurchaseOrderLine[]
  costLogs           IngredientCostLog[]
  storageMappings    IngredientStorageMapping[]
  countLines         InventoryCountLine[]
  recipeLines        RecipeLine[]
  adjustments        InventoryAdjustment[]
  storePars          StoreIngredientPar[]
  linkedMessages     TeamMessage[]
}

model IngredientCostLog {
  id                   String   @id @default(cuid())
  ingredientId         String
  costPerReportingUnit Float
  source               String // PO_RECEIPT | MANUAL | IMPORT
  sourceRef            String?
  createdAt            DateTime @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
}

model IngredientDuplicateDismissal {
  id             String   @id @default(cuid())
  organizationId String
  ingredientAId  String
  ingredientBId  String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, ingredientAId, ingredientBId])
}

model InventoryCount {
  id                  String    @id @default(cuid())
  organizationId      String
  storeId             String
  name                String?
  notes               String?
  isPartial           Boolean   @default(false)
  startedAt           DateTime  @default(now())
  finalizedAt         DateTime?
  completedByUserIds  String[]
  sittingInventoryVal Float?
  status              String    @default("Draft") // Draft | Finalized

  organization Organization               @relation(fields: [organizationId], references: [id])
  store        Store                      @relation(fields: [storeId], references: [id])
  lines        InventoryCountLine[]
  corrections  InventoryCountCorrection[]
}

// One line per (storage area, ingredient) assignment, snapshotted when the draft
// is created — name/unit/cost frozen at count start so later price changes never
// rewrite a finalized count. quantityCounted null = not yet counted (distinct
// from an explicit 0 on the shelf).
model InventoryCountLine {
  id                   String    @id @default(cuid())
  inventoryCountId     String
  storageAreaId        String?
  ingredientId         String
  ingredientName       String
  reportingUnit        String
  quantityCounted      Float?
  costPerReportingUnit Float
  lineValue            Float?
  usageVariance        Float?
  sortOrder            Int       @default(0)
  countedAt            DateTime?

  inventoryCount InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  storageArea    StorageArea?   @relation(fields: [storageAreaId], references: [id])
  ingredient     Ingredient     @relation(fields: [ingredientId], references: [id])
}

// Audit trail for post-finalize corrections — one row per changed field. The
// count total is recomputed but the original entry stays explainable.
model InventoryCountCorrection {
  id        String   @id @default(cuid())
  countId   String
  lineId    String
  field     String // quantityCounted | costPerReportingUnit
  oldValue  Float?
  newValue  Float?
  note      String?
  userId    String
  createdAt DateTime @default(now())

  count InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
}

// ─── PHASE I-5: SALES CACHES (Square Orders → local aggregates) ──────────────
// Populated by the sales sync (SearchOrders, COMPLETED, closed_at). Dates and
// hours are bucketed in the STORE's timezone. Sync is idempotent per day: a
// re-sync replaces the covered days wholesale.

model SalesPeriodCache {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  date           DateTime @db.Date
  grossSales     Float    @default(0) // total collected: incl. tax + tips, after discounts
  netSales       Float    @default(0) // sales metric: gross − tax − tips (excludes tax & tips)
  unconfirmedNet Float    @default(0) // portion of netSales from paid-but-OPEN orders (not yet confirmed in the POS)
  taxTotal       Float    @default(0)
  tipTotal       Float    @default(0)
  discountTotal  Float    @default(0)
  orderCount     Int      @default(0)
  syncedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([organizationId, date])
}

// Per Square variation per day — feeds the Item Sales report now and
// theoretical usage / variance in I-6.
model SalesLineCache {
  id                String   @id @default(cuid())
  organizationId    String
  storeId           String
  date              DateTime @db.Date
  squareVariationId String
  quantitySold      Float    @default(0)
  grossSales        Float    @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, squareVariationId])
  @@index([storeId, date])
}

// Hourly pace — feeds the Dashboard (D-1) intraday chart.
model SalesHourlyCache {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  date           DateTime @db.Date
  hour           Int // 0–23, store-local
  netSales       Float    @default(0)
  orderCount     Int      @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, hour])
  @@index([storeId, date])
}

// ─── PHASE D-1: DASHBOARD ─────────────────────────────────────────────────────

// Monthly sales goal per store (month = first-of-month UTC date). Managers and
// admins set it; the Dashboard's Monthly Goal card reads it.
model StoreMonthlyGoal {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  month          DateTime @db.Date
  goalAmount     Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, month])
}

// ─── PHASE I-6: RECIPES, ADJUSTMENTS, TRANSFERS, LOSS & PREP ─────────────────
// Recipes NEVER write to Square — a recipe attaches to a variation via
// salesItemId only; all Square fields on SalesItem stay read-only.

// salesItemId null = sub-recipe/batch (e.g. "Cup Kit - 32oz") usable as a line
// inside other recipes. servingSize* pre-fills the amount field when this
// recipe is added as a line in the editor. Costs are computed at read time
// (src/lib/recipe-cost.ts) — never stored on the recipe.
model Recipe {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  salesItemId     String?  @unique
  yieldQty        Float    @default(1)
  yieldUnit       String   @default("serving")
  servingSizeQty  Float?
  servingSizeUnit String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization       Organization @relation(fields: [organizationId], references: [id])
  salesItem          SalesItem?   @relation(fields: [salesItemId], references: [id])
  lines              RecipeLine[]
  usedIn             RecipeLine[] @relation("SubRecipeLine")
  preparedIngredient Ingredient?  @relation("PreparedIngredient")

  @@index([organizationId])
}

// Exactly one of ingredientId/subRecipeId is set (enforced in Zod). unit is a
// usage unit convertible to the ingredient's reporting-unit dimension.
model RecipeLine {
  id           String  @id @default(cuid())
  recipeId     String
  ingredientId String?
  subRecipeId  String?
  amount       Float
  unit         String
  sortOrder    Int     @default(0)

  recipe     Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id])
  subRecipe  Recipe?     @relation("SubRecipeLine", fields: [subRecipeId], references: [id])

  @@index([recipeId])
  @@index([subRecipeId])
}

// Header for multi-line stock movements: one transfer / loss entry / prep batch
// = one group + its InventoryAdjustment rows. TRANSFER: fromStoreId (+ toStoreId,
// or destinationLabel for non-tracked destinations like "Kitchen"). PREP:
// recipeId + batchMultiplier enable the "re-record" shortcut. occurredAt is
// backdatable so rows land in the right inventory period.
model AdjustmentGroup {
  id               String   @id @default(cuid())
  organizationId   String
  type             String // TRANSFER | LOSS | PREP
  fromStoreId      String?
  toStoreId        String?
  destinationLabel String?
  recipeId         String?
  batchMultiplier  Float?
  occurredAt       DateTime
  note             String?
  createdByUserId  String
  createdAt        DateTime @default(now())

  organization Organization          @relation(fields: [organizationId], references: [id])
  fromStore    Store?                @relation("AdjustmentGroupFromStore", fields: [fromStoreId], references: [id])
  toStore      Store?                @relation("AdjustmentGroupToStore", fields: [toStoreId], references: [id])
  adjustments  InventoryAdjustment[]

  @@index([organizationId, occurredAt])
}

// quantity is the SIGNED stock effect in reporting units: negative reduces
// on-hand (WASTE, COMP, TRANSFER_OUT, PREP_CONSUME), positive increases it
// (TRANSFER_IN, PREP_PRODUCE), CORRECTION is either. value = quantity × cost.
// APIs accept positive user input and apply the sign. occurredAt (backdatable)
// buckets the row into an inventory period; createdAt is the audit timestamp.
model InventoryAdjustment {
  id                   String   @id @default(cuid())
  organizationId       String
  storeId              String
  ingredientId         String
  ingredientName       String
  type                 String // WASTE | TRANSFER_IN | TRANSFER_OUT | COMP | CORRECTION | PREP_CONSUME | PREP_PRODUCE
  quantity             Float
  costPerReportingUnit Float
  value                Float
  reason               String?
  lossReasonId         String?
  groupId              String?
  occurredAt           DateTime @default(now())
  createdByUserId      String
  createdAt            DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  store        Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient       @relation(fields: [ingredientId], references: [id])
  lossReason   LossReason?      @relation(fields: [lossReasonId], references: [id])
  group        AdjustmentGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([storeId, occurredAt])
  @@index([organizationId, occurredAt])
  @@index([groupId])
}

// Seeded per org: Spoilage, Breakage, Comp, Theft/Unknown (isDefault). Orgs add
// custom reasons; referenced rows keep reasons from being deleted (no cascade).
model LossReason {
  id             String  @id @default(cuid())
  organizationId String
  label          String
  isDefault      Boolean @default(false)
  sortOrder      Int     @default(0)

  organization Organization          @relation(fields: [organizationId], references: [id])
  adjustments  InventoryAdjustment[]

  @@unique([organizationId, label])
}

// Manual sold-quantity correction on the Variance report ONLY — Square sales
// data stays untouched. periodKey = "<beginCountId>_<endCountId>". One row per
// (store, salesItem, period); the API upserts.
model VarianceAdjustment {
  id              String   @id @default(cuid())
  organizationId  String
  storeId         String
  salesItemId     String
  periodKey       String
  qtyDelta        Float
  note            String?
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  salesItem    SalesItem    @relation(fields: [salesItemId], references: [id])

  @@unique([storeId, salesItemId, periodKey])
}

// ─── PHASE I-7: PARS, REORDER POINTS & SMART ORDERING ────────────────────────

// Par level and reorder point per ingredient per store, in the ingredient's
// REPORTING unit (the UI shows the purchase-unit equivalent via units.ts).
// A low-stock alert fires when expected on-hand < reorderPoint (parLevel when
// no reorder point is set — reorder point wins when both exist); Smart Cart's
// fill-to-par restocks to parLevel. Distinct from the legacy
// ItemMetadata.parLevel Square-catalog stub, which stays untouched.
model StoreIngredientPar {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  ingredientId   String
  parLevel       Float?
  reorderPoint   Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([storeId, ingredientId])
  @@index([organizationId])
}

// ─── PHASE 2: NUTRITION MODULE ────────────────────────────────────────────────

model MenuItem {
  id                 String   @id @default(cuid())
  organizationId     String
  squareCatalogObjId String?
  name               String
  description        String?
  category           String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id])
  nutrition    MenuItemNutrition?
  allergens    MenuItemAllergen[]
}

model MenuItemNutrition {
  id            String  @id @default(cuid())
  menuItemId    String  @unique
  servingSize   String?
  calories      Int?
  totalFatG     Float?
  saturatedFatG Float?
  transFatG     Float?
  cholesterolMg Float?
  sodiumMg      Float?
  totalCarbG    Float?
  dietaryFiberG Float?
  totalSugarsG  Float?
  addedSugarsG  Float?
  proteinG      Float?
  vitaminDMcg   Float?
  calciumMg     Float?
  ironMg        Float?
  potassiumMg   Float?

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model MenuItemAllergen {
  id         String @id @default(cuid())
  menuItemId String
  allergen   String

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, allergen])
}

// ─── PHASE F: SALES GOALS & FORECASTING ──────────────────────────────────────
// One GoalPlan per store per year. DailyGoal rows are MATERIALIZED (not
// computed on read) so the calendar is one indexed query and manual overrides
// are first-class rows. basisAmount is stored per day so the increase % can be
// re-applied at any time without re-querying Square. Actuals come from
// SalesPeriodCache (I-5) — Square is never read on a dashboard/calendar path.

enum GoalBasisType {
  SQUARE_LAST_YEAR
  IMPORT
  MANUAL
}

model GoalPlan {
  id             String        @id @default(cuid())
  organizationId String
  storeId        String
  year           Int
  basisType      GoalBasisType
  basisTotal     Float         @default(0)
  increasePct    Float         @default(0)
  goalTotal      Float         @default(0) // derived, denormalized
  importFileUrl  String? // Vercel Blob URL when basisType = IMPORT
  updatedById    String // Clerk user id of last editor
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  dailyGoals   DailyGoal[]

  @@unique([storeId, year])
  @@index([organizationId, year])
}

model DailyGoal {
  id          String   @id @default(cuid())
  planId      String
  storeId     String
  date        DateTime @db.Date
  basisAmount Float    @default(0) // LY same-weekday sales or imported value
  goalAmount  Float    @default(0)
  isOverride  Boolean  @default(false) // manually edited — survives % recalcs

  plan  GoalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  store Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([planId])
}

// ─── PHASE I-14: TEAM MESSAGING (Phase 1) ────────────────────────────────────
// Every post is structured data: `type` drives filtering and later automation
// (a shortage with linkedIngredientId can flag inventory with no schema change).
// The postedTo*/source* trio powers checklist handoff notes — NULL on regular
// feed posts. Soft delete + editedAt keep an audit trail for staffing and
// customer-complaint documentation.

model TeamMessage {
  id                   String    @id @default(cuid())
  organizationId       String
  storeId              String
  // authorUser = the logged-in account; authorStaff = the optional "who is
  // posting" pick from the store roster (same split as TaskLog completedBy*).
  authorUserId         String?
  authorStaffId        String?
  type                 String    @default("general") // shift_note | shortage | equipment | customer_feedback | staffing | shoutout | general
  shiftPhase           String? // opening | mid | closing — set when type = shift_note
  body                 String
  linkedIngredientId   String? // shortage → inventory tie-in (module-gated in UI)
  // Checklist handoff: which template's instance this note renders on, for
  // which day, and which checklist the author was working when they posted.
  postedToTemplateId   String?
  postedForDate        DateTime? @db.Date
  sourceChecklistId    String?
  status               String    @default("open") // open | resolved | archived — free ticket system for shortage/equipment
  resolvedByUserId     String?
  resolvedAt           DateTime?
  // Handoff lifecycle: explicit Acknowledge (not viewing) clears a note from
  // checklist banners and the dashboard; expiresAt bounds how long an
  // unacknowledged note keeps surfacing (org-configurable, from postedForDate).
  acknowledgedAt       DateTime?
  acknowledgedByUserId String?
  expiresAt            DateTime?
  createdAt            DateTime  @default(now())
  editedAt             DateTime?
  deletedAt            DateTime?

  organization       Organization        @relation(fields: [organizationId], references: [id])
  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  authorUser         User?               @relation("TeamMessageAuthor", fields: [authorUserId], references: [id])
  authorStaff        StaffMember?        @relation(fields: [authorStaffId], references: [id])
  resolvedByUser     User?               @relation("TeamMessageResolver", fields: [resolvedByUserId], references: [id])
  acknowledgedByUser User?               @relation("TeamMessageAcknowledger", fields: [acknowledgedByUserId], references: [id])
  linkedIngredient   Ingredient?         @relation(fields: [linkedIngredientId], references: [id])
  postedToTemplate   Template?           @relation("HandoffTarget", fields: [postedToTemplateId], references: [id])
  sourceChecklist    Checklist?          @relation("HandoffSource", fields: [sourceChecklistId], references: [id])
  attachments        MessageAttachment[]
  reactions          MessageReaction[]
  reads              MessageRead[]

  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, postedToTemplateId, postedForDate])
  @@index([organizationId, createdAt(sort: Desc)])
}

// Attached to EITHER a team message or a corporate update (exactly one —
// enforced in the routes; both FKs cascade). kind=youtube stores the canonical
// watch URL (no blob); image/document store the Vercel Blob URL.
model MessageAttachment {
  id                String   @id @default(cuid())
  messageId         String?
  corporateUpdateId String?
  kind              String // image | document | youtube
  url               String
  filename          String?
  contentType       String?
  sizeBytes         Int?
  createdAt         DateTime @default(now())

  message         TeamMessage?     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  corporateUpdate CorporateUpdate? @relation(fields: [corporateUpdateId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([corporateUpdateId])
}

// One reaction per emoji per user, enforced by the unique. Emoji set is
// allow-listed in the route (👍 🎉 ❤️ 😂 👀 🙏).
model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message TeamMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

// Powers unread badges now; Phase 2 corporate-update acknowledgments reuse the
// same pattern.
model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message TeamMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

// Minimal Phase 1 version — powers the dashboard CORPORATE UPDATE box.
// Acknowledgments and Twilio notifications are Phase 2+.
model CorporateUpdate {
  id             String    @id @default(cuid())
  organizationId String
  authorUserId   String // admin only, enforced in routes
  title          String
  body           String
  storeIds       String[]  @default([]) // empty = visible to all stores
  pinnedUntil    DateTime? // stays in the dashboard box until this date
  publishedAt    DateTime? // NULL = draft
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id])
  authorUser   User                @relation(fields: [authorUserId], references: [id])
  attachments  MessageAttachment[]

  @@index([organizationId, publishedAt(sort: Desc)])
}

// ─── HR, TRAINING & COMPLIANCE MODULE ────────────────────────────────────────
// Forward-compat schema (HR-0): models exist; no app code reads them yet beyond
// the availability gate + activeModules "hr" toggle. Runs PARALLEL to Square
// Payroll — Froot never stores SSN / W-4 / I-9 / bank data. Froot owns the
// internal-document layer: acknowledgments, signed records, fillable
// agreements, manager notes, and trackable training.

enum HrCheckpointType {
  Field
  Initial
  Signature
  Acknowledgment
}

enum HrAckMethod {
  Field
  Initial
  Signature
  ReadReceipt
  Attested
}

enum HrAuthMethod {
  ClerkSession
  Kiosk
  ManagerAttested
}

// An internal document (handbook, pay agreement, policy...). The FILE lives on
// versions; checkpoints/fields describe what a staff member must sign or fill.
// linkedFormId pairs Check-Out ↔ Check-In style forms.
model HrDocument {
  id                     String   @id @default(cuid())
  organizationId         String
  kind                   String // Acknowledgment | FillableForm | Reference
  title                  String
  category               String // Handbook | PayAgreement | Policy | HRManagement | Other
  appliesTo              String   @default("all") // all | selected (store assignments below)
  requiresAcknowledgment Boolean  @default(false)
  isActive               Boolean  @default(true)
  linkedFormId           String? // Check-Out ↔ Check-In form pairing
  bodyText               String? // FillableForm: the agreement's fixed language, rendered above the fields
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization     Organization                @relation(fields: [organizationId], references: [id])
  versions         HrDocumentVersion[]
  checkpoints      HrDocumentCheckpoint[]
  formFields       FormField[]
  storeAssignments HrDocumentStoreAssignment[]

  @@index([organizationId])
}

model HrDocumentStoreAssignment {
  id           String @id @default(cuid())
  hrDocumentId String
  storeId      String

  hrDocument HrDocument @relation(fields: [hrDocumentId], references: [id], onDelete: Cascade)
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([hrDocumentId, storeId])
}

// Immutable file snapshot per upload. fileHash (sha256 of the exact bytes) is
// the version pin acknowledgments reference — never overwrite a version's file.
//
// FillableForm versions (HR-5) have no uploaded file: the definition (bodyText
// + fields) is snapshotted in definitionSnapshot, fileHash holds the sha256 of
// the canonical definition JSON, and the file columns carry sentinels
// (fileUrl "", contentType application/x-froot-form-definition, sizeBytes =
// JSON byte length). Same pin semantics, no nullability change for HR-4.
model HrDocumentVersion {
  id                 String   @id @default(cuid())
  hrDocumentId       String
  versionNumber      Int
  fileUrl            String
  fileName           String
  contentType        String
  sizeBytes          Int
  fileHash           String // sha256 (file bytes, or canonical form-definition JSON)
  definitionSnapshot Json? // FillableForm: frozen { bodyText, fields } this version pins
  isCurrent          Boolean  @default(true)
  uploadedByUserId   String
  createdAt          DateTime @default(now())

  hrDocument      HrDocument                 @relation(fields: [hrDocumentId], references: [id], onDelete: Cascade)
  acknowledgments HrDocumentAcknowledgment[]
  formSubmissions FormSubmission[]
  signedRecords   HrSignedRecord[]

  @@unique([hrDocumentId, versionNumber])
}

// Confirmed by the HR-0a spike against the real 2026 Employee Handbook
// (35 checkpoints: 3 Field, 27 Initial, 1 Signature, 4 Acknowledgment).
model HrDocumentCheckpoint {
  id              String           @id @default(cuid())
  hrDocumentId    String
  name            String // e.g. "Page 7 initial", "Final Employee Handbook acknowledgment"
  type            HrCheckpointType
  orderIndex      Int
  pageRef         Int? // page anchor -> enables in-page stamping later
  attestationText String? // present for Acknowledgment; the "I have read and understand..." text
  required        Boolean          @default(true)

  hrDocument      HrDocument                 @relation(fields: [hrDocumentId], references: [id], onDelete: Cascade)
  acknowledgments HrDocumentAcknowledgment[]
}

// The defensible signed record. staffMemberId/userId are intentionally plain
// strings (no FK): the snapshot columns below are the record of who signed
// what, frozen at signing time — they must survive any later edit or delete.
model HrDocumentAcknowledgment {
  id                    String       @id @default(cuid())
  checkpointId          String
  hrDocumentVersionId   String
  staffMemberId         String?
  userId                String?
  // --- snapshots frozen at signing time (survive later edits) ---
  checkpointName        String
  checkpointType        String
  documentTitle         String
  documentVersionNumber Int
  documentFileHash      String // sha256 of the exact bytes signed (version pin)
  staffName             String
  storeName             String?
  attestationText       String?
  // --- what was captured ---
  method                HrAckMethod
  typedName             String?
  signatureImageUrl     String? // for drawn signatures (nullable)
  fieldValue            String? // for Field checkpoints
  // --- audit / ESIGN evidence ---
  signedAt              DateTime     @default(now())
  ipAddress             String?
  userAgent             String?
  authMethod            HrAuthMethod
  consentGiven          Boolean
  consentText           String?
  consentVersion        String?

  checkpoint HrDocumentCheckpoint @relation(fields: [checkpointId], references: [id])
  version    HrDocumentVersion    @relation(fields: [hrDocumentVersionId], references: [id])

  @@unique([checkpointId, hrDocumentVersionId, staffMemberId])
}

// HR-4: the executed-document artifact — one per (version, staff), created
// when every required checkpoint for that version is complete. Append-only:
// no update/delete path exists. FKs deliberately have no cascade, so a signed
// record blocks deletion of the version/staff it pins.
model HrSignedRecord {
  id                  String   @id @default(cuid())
  hrDocumentVersionId String
  staffMemberId       String
  completedAt         DateTime // when the last required checkpoint was signed
  signedPdfPathname   String // pathname in the PRIVATE froot-hr Blob store
  signedPdfHash       String // sha256 of the generated signed PDF bytes
  generatedAt         DateTime @default(now())

  version     HrDocumentVersion @relation(fields: [hrDocumentVersionId], references: [id])
  staffMember StaffMember       @relation(fields: [staffMemberId], references: [id])

  @@unique([hrDocumentVersionId, staffMemberId])
  @@index([staffMemberId])
}

// Field definitions for kind=FillableForm documents. These rows are the
// EDITABLE current definition; the signed copy lives in each version's
// definitionSnapshot, so submissions never depend on these rows.
model FormField {
  id           String  @id @default(cuid())
  hrDocumentId String
  label        String
  fieldType    String // Text | Date | Email | Phone | Number | Select (FORM_FIELD_TYPES)
  required     Boolean @default(true)
  orderIndex   Int     @default(0)
  options      Json? // Select: array of choice strings

  hrDocument HrDocument @relation(fields: [hrDocumentId], references: [id], onDelete: Cascade)
}

// A staff member's execution of a fillable form (HR-5). Pinned to the document
// VERSION they filled; no cascade — submissions are records and outlive form
// edits. Re-execution is first-class: NO unique on (version, staff) — pay
// agreements and key check-outs recur, so a staff member accumulates
// submissions over time. Append-only: after create, the only writes ever
// allowed are the supervisor countersign block (once, while
// PendingSupervisor) and the three write-once signedPdf* columns. The
// executed PDF lives HERE, not on HrSignedRecord (that stays acknowledgment-
// only, keyed one-per-version-per-staff).
model FormSubmission {
  id                     String   @id @default(cuid())
  hrDocumentVersionId    String
  staffMemberId          String
  values                 Json
  employeeSignatureUrl   String? // unused: HR-4/5 capture is typed-name (kept for drawn signatures later)
  supervisorSignatureUrl String?
  signedAt               DateTime @default(now())
  ipAddress              String? // employee-side audit (supervisor block below)
  userAgent              String?
  // --- dual-signer execution (HR-5) ---
  status                 String    @default("PendingSupervisor") // PendingSupervisor | Completed
  supervisorUserId       String?
  employeeTypedName      String?
  supervisorTypedName    String?
  employeeSignedAt       DateTime?
  supervisorSignedAt     DateTime?
  supervisorIpAddress    String?
  supervisorUserAgent    String?
  // --- snapshots frozen at signing time (survive later edits) ---
  formTitle              String?
  formVersionNumber      Int?
  staffName              String?
  storeName              String?
  definitionHash         String? // sha256 of the definition JSON signed (version pin)
  consentText            String?
  consentVersion         String?
  // --- executed artifact in the PRIVATE froot-hr store; write-once ---
  signedPdfPathname      String?
  signedPdfHash          String? // sha256 of the generated PDF bytes
  generatedAt            DateTime?

  version     HrDocumentVersion @relation(fields: [hrDocumentVersionId], references: [id])
  staffMember StaffMember       @relation(fields: [staffMemberId], references: [id])

  @@index([staffMemberId])
  @@index([hrDocumentVersionId])
}

// Private manager log per staff member (conversations, attendance, coaching).
model ManagerNote {
  id             String   @id @default(cuid())
  organizationId String
  staffMemberId  String
  authorUserId   String
  category       String // Conversation | Attendance | Coaching | Feedback | General
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  staffMember  StaffMember  @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([staffMemberId, createdAt(sort: Desc)])
  @@index([organizationId])
}

model TrainingModule {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  subject        String?
  description    String?
  appliesTo      String   @default("all") // all | selected (store assignments below)
  isActive       Boolean  @default(true)
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization                    @relation(fields: [organizationId], references: [id])
  lessons          TrainingLesson[]
  quizzes          TrainingQuiz[]
  assignments      TrainingAssignment[]
  storeAssignments TrainingModuleStoreAssignment[]

  @@index([organizationId])
}

model TrainingModuleStoreAssignment {
  id               String @id @default(cuid())
  trainingModuleId String
  storeId          String

  trainingModule TrainingModule @relation(fields: [trainingModuleId], references: [id], onDelete: Cascade)
  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([trainingModuleId, storeId])
}

model TrainingLesson {
  id               String  @id @default(cuid())
  trainingModuleId String
  title            String
  info             String?
  videoUrl         String?
  orderIndex       Int     @default(0)

  trainingModule TrainingModule           @relation(fields: [trainingModuleId], references: [id], onDelete: Cascade)
  resources      TrainingResource[]
  progress       TrainingLessonProgress[]
}

// Downloadable attachments per lesson (UI caps at 4/lesson).
model TrainingResource {
  id               String @id @default(cuid())
  trainingLessonId String
  label            String
  fileUrl          String
  contentType      String
  sizeBytes        Int

  trainingLesson TrainingLesson @relation(fields: [trainingLessonId], references: [id], onDelete: Cascade)
}

// Quiz per module; questions stay Json until the quiz builder phase.
model TrainingQuiz {
  id               String @id @default(cuid())
  trainingModuleId String
  passThreshold    Int    @default(80)
  questions        Json

  trainingModule TrainingModule @relation(fields: [trainingModuleId], references: [id], onDelete: Cascade)
}

// One staff member's run through a module. No cascade from the module —
// completed/certified assignments are records.
model TrainingAssignment {
  id               String    @id @default(cuid())
  trainingModuleId String
  staffMemberId    String
  assignedByUserId String
  trainerUserId    String?
  dueDate          DateTime?
  status           String    @default("NotStarted") // NotStarted | InProgress | Completed
  hoursLogged      Float?
  certifiedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  trainingModule TrainingModule           @relation(fields: [trainingModuleId], references: [id])
  staffMember    StaffMember              @relation(fields: [staffMemberId], references: [id])
  lessonProgress TrainingLessonProgress[]

  @@index([staffMemberId])
  @@index([trainingModuleId])
}

model TrainingLessonProgress {
  id                   String   @id @default(cuid())
  trainingAssignmentId String
  trainingLessonId     String
  completedAt          DateTime @default(now())
  completedByStaffId   String?

  trainingAssignment TrainingAssignment @relation(fields: [trainingAssignmentId], references: [id], onDelete: Cascade)
  trainingLesson     TrainingLesson     @relation(fields: [trainingLessonId], references: [id], onDelete: Cascade)
  completedByStaff   StaffMember?       @relation(fields: [completedByStaffId], references: [id])

  @@unique([trainingAssignmentId, trainingLessonId])
}

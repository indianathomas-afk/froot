generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── CORE (Phase 1) ──────────────────────────────────────────────────────────

model Organization {
  id                   String    @id @default(cuid())
  clerkOrgId           String    @unique
  name                 String
  slug                 String?   @unique
  squareCustomerId     String?
  squareSubscriptionId String?
  subscriptionStatus   String?   @default("inactive")
  activeModules        String[]  @default([])
  squareAccessToken    String?
  squareRefreshToken   String?
  squareTokenExpiresAt DateTime?
  lastCatalogSyncAt    DateTime?
  createdAt            DateTime  @default(now())

  stores               Store[]
  users                User[]
  pendingInvites       PendingInvite[]
  staff                StaffMember[]
  templates            Template[]
  checklists           Checklist[]
  storageAreas         StorageArea[]
  inventoryCounts      InventoryCount[]
  itemMetadata         ItemMetadata[]
  menuItems            MenuItem[]
  auditLogs            AuditLog[]
  catalogCategories    CatalogCategory[]
  catalogItems         CatalogItem[]
  vendors              Vendor[]
  purchaseOrders       PurchaseOrder[]
  squareCategories     SquareCategory[]
  salesItems           SalesItem[]
  ingredientCategories IngredientCategory[]
  ingredients          Ingredient[]
  ingredientDuplicateDismissals IngredientDuplicateDismissal[]
  salesPeriodCaches    SalesPeriodCache[]
  salesLineCaches      SalesLineCache[]
  salesHourlyCaches    SalesHourlyCache[]
  storeMonthlyGoals    StoreMonthlyGoal[]
}

model User {
  id             String   @id @default(cuid())
  clerkUserId    String   @unique
  organizationId String
  email          String
  name           String?
  role           Role     @default(STAFF)
  createdAt      DateTime @default(now())

  organization     Organization          @relation(fields: [organizationId], references: [id])
  storeAssignments StoreUserAssignment[]
  taskLogs         TaskLog[]
}

model Store {
  id               String   @id @default(cuid())
  organizationId   String
  squareLocationId String?  @unique
  storeNumber      String?
  name             String
  brand            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  timezone         String   @default("America/Los_Angeles")
  contactEmail     String?
  phoneNumber      String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  organization        Organization              @relation(fields: [organizationId], references: [id])
  hours               StoreHours[]
  userAssignments     StoreUserAssignment[]
  staffAssignments    StoreStaffAssignment[]
  templateAssignments TemplateStoreAssignment[]
  checklists          Checklist[]
  storageAreas        StorageArea[]
  inventoryCounts     InventoryCount[]
  purchaseOrders      PurchaseOrder[]
  salesPeriodCaches   SalesPeriodCache[]
  salesLineCaches     SalesLineCache[]
  salesHourlyCaches   SalesHourlyCache[]
  monthlyGoals        StoreMonthlyGoal[]
}

model StoreHours {
  id          String  @id @default(cuid())
  storeId     String
  dayOfWeek   Int
  openingTime String?
  closingTime String?
  isClosed    Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreUserAssignment {
  id      String @id @default(cuid())
  userId  String
  storeId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model PendingInvite {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           Role
  storeIds       String[] @default([])
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
}

model StaffMember {
  id                 String   @id @default(cuid())
  organizationId     String
  squareTeamMemberId String?  @unique
  displayName        String
  fullName           String?
  email              String?
  createdAt          DateTime @default(now())

  organization     Organization           @relation(fields: [organizationId], references: [id])
  storeAssignments StoreStaffAssignment[]
  taskLogs         TaskLog[]
}

model StoreStaffAssignment {
  id            String @id @default(cuid())
  staffMemberId String
  storeId       String

  staffMember StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([staffMemberId, storeId])
}

model Template {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  type             String
  frequency        String   @default("Daily")
  availabilityType String   @default("StoreHours")
  operationalPhase String?
  startOffsetHours Int?
  endOffsetHours   Int?
  isActive         Boolean  @default(true)
  isArchived       Boolean  @default(false)
  appliesTo        String   @default("all")
  createdAt        DateTime @default(now())

  organization     Organization              @relation(fields: [organizationId], references: [id])
  storeAssignments TemplateStoreAssignment[]
  tasks            Task[]
  checklists       Checklist[]
}

model TemplateStoreAssignment {
  id         String @id @default(cuid())
  templateId String
  storeId    String

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([templateId, storeId])
}

model Task {
  id                   String   @id @default(cuid())
  templateId           String
  sectionName          String
  description          String
  estimatedTimeMinutes Float?
  requiresPhoto        Boolean  @default(false)
  requiresTemp         Boolean  @default(false)
  isCritical           Boolean  @default(false)
  orderIndex           Int      @default(0)
  excludedStoreIds     String[]
  videoUrl             String?

  template   Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  taskLogs   TaskLog[]
  attachment TaskAttachment?
}

model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String   @unique
  label       String
  url         String
  contentType String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Checklist {
  id             String    @id @default(cuid())
  organizationId String
  templateId     String
  storeId        String
  date           DateTime
  status         String    @default("Pending")
  startedAt      DateTime?
  completedAt    DateTime?
  completionRate Float?    @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  template     Template     @relation(fields: [templateId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  taskLogs     TaskLog[]
}

model TaskLog {
  id                 String   @id @default(cuid())
  checklistId        String
  taskId             String
  completedByUserId  String?
  completedByStaffId String?
  completedAt        DateTime @default(now())
  photoUrl           String?
  temperatureValue   Float?
  notes              String?

  checklist        Checklist    @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  task             Task         @relation(fields: [taskId], references: [id])
  completedByUser  User?        @relation(fields: [completedByUserId], references: [id])
  completedByStaff StaffMember? @relation(fields: [completedByStaffId], references: [id])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  STORE
}

// ─── PHASE 2: INVENTORY MODULE ────────────────────────────────────────────────

model StorageArea {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  name           String
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  organization       Organization               @relation(fields: [organizationId], references: [id])
  store              Store                      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ingredientMappings IngredientStorageMapping[]
  countLines         InventoryCountLine[]
}

// Per-store assignment of an ingredient to a storage area. An ingredient may map
// into multiple areas of the same store; sortOrder is the shelf-to-sheet count order.
model IngredientStorageMapping {
  id            String @id @default(cuid())
  storageAreaId String
  ingredientId  String
  sortOrder     Int    @default(0)

  storageArea StorageArea @relation(fields: [storageAreaId], references: [id], onDelete: Cascade)
  ingredient  Ingredient  @relation(fields: [ingredientId], references: [id])

  @@unique([storageAreaId, ingredientId])
}

model ItemMetadata {
  id                 String   @id @default(cuid())
  organizationId     String
  squareCatalogObjId String
  vendorName         String?
  vendorId           String?
  glCode             String?
  parLevel           Float?
  unitCostOverride   Float?
  unitOfMeasure      String?
  notes              String?
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])

  @@unique([organizationId, squareCatalogObjId])
}

model CatalogCategory {
  id               String  @id @default(cuid())
  organizationId   String
  squareCategoryId String
  name             String
  isDeleted        Boolean @default(false)
  sortOrder        Int     @default(0)

  organization Organization  @relation(fields: [organizationId], references: [id])
  items        CatalogItem[]

  @@unique([organizationId, squareCategoryId])
}

model CatalogItem {
  id             String   @id @default(cuid())
  organizationId String
  squareItemId   String?
  categoryId     String?
  name           String
  description    String?
  isDeleted      Boolean  @default(false)
  isArchived     Boolean  @default(false)
  productType    String?
  updatedAt      DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id])
  category     CatalogCategory?       @relation(fields: [categoryId], references: [id])
  variations   CatalogItemVariation[]

  @@unique([organizationId, squareItemId])
}

model CatalogItemVariation {
  id                String  @id @default(cuid())
  catalogItemId     String
  squareVariationId String?
  name              String
  sku               String?
  priceMoney        Int?
  ordinal           Int     @default(0)

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([catalogItemId, squareVariationId])
}

model Vendor {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  accountNumber  String?
  contactName    String?
  email          String?
  phone          String?
  terms          String?
  leadTimeDays   Int?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization      Organization       @relation(fields: [organizationId], references: [id])
  vendorIngredients VendorIngredient[]
  purchaseOrders    PurchaseOrder[]
  itemMetadata      ItemMetadata[]
}

model VendorIngredient {
  id              String  @id @default(cuid())
  vendorId        String
  ingredientId    String
  vendorSku       String?
  packDescription String?
  casePrice       Float?
  unitsPerCase    Float?

  vendor     Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([vendorId, ingredientId])
}

model PurchaseOrder {
  id              String    @id @default(cuid())
  organizationId  String
  storeId         String
  vendorId        String
  poNumber        String
  invoiceNumber   String?
  orderedAt       DateTime?
  expectedAt      DateTime?
  totalAmount     Float     @default(0)
  status          String    @default("DRAFT")
  enteredByUserId String?
  receivedAt      DateTime? // set when the PO reaches RECEIVED (fully received)
  createdAt       DateTime  @default(now())

  organization Organization        @relation(fields: [organizationId], references: [id])
  store        Store               @relation(fields: [storeId], references: [id])
  vendor       Vendor              @relation(fields: [vendorId], references: [id])
  lines        PurchaseOrderLine[]

  @@unique([organizationId, poNumber])
}

model PurchaseOrderLine {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  ingredientId     String
  ingredientName   String
  quantityOrdered  Float
  quantityReceived Float     @default(0)
  unitCost         Float
  lineTotal        Float
  receivingNote    String?
  receivedAt       DateTime? // last receipt timestamp — places the received value in an inventory period

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])
}

// ─── PHASE 2: INVENTORY MODULE v2 — sales items (Square) vs ingredients (Froot) ──

model SquareCategory {
  id               String  @id @default(cuid())
  organizationId   String
  squareCategoryId String
  name             String
  isDeleted        Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id])
  salesItems   SalesItem[]

  @@unique([organizationId, squareCategoryId])
}

model SalesItem {
  id                String   @id @default(cuid())
  organizationId    String
  squareItemId      String
  squareVariationId String
  name              String
  variationName     String
  displayName       String
  squareCategoryId  String?
  menuGroup         String?
  priceCents        Int?
  isDeleted         Boolean  @default(false)
  updatedAt         DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  squareCategory SquareCategory? @relation(fields: [squareCategoryId], references: [id])

  @@unique([organizationId, squareVariationId])
}

model IngredientCategory {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  glCode         String?
  sortOrder      Int     @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  ingredients  Ingredient[]

  @@unique([organizationId, name])
}

model Ingredient {
  id                   String    @id @default(cuid())
  organizationId       String
  brand                String?
  name                 String
  categoryId           String?
  subcategory          String?
  sku                  String?
  purchaseUnitLabel    String
  packDescription      String?
  purchaseCost         Float
  reportingUnit        String
  unitsPerPurchase     Float
  costPerReportingUnit Float
  glCodeOverride       String?
  productNote          String?
  isActive             Boolean   @default(true)
  isArchived           Boolean   @default(false)
  deletedAt            DateTime?
  lastEditedByUserId   String?
  kind                 String    @default("PURCHASED") // PURCHASED | PREPARED
  // Count-by-weighing container weights, stored in oz (dry). tare = empty
  // container, full = full container (full only needed for volume/count items).
  tareWeightOz         Float?
  fullWeightOz         Float?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization       Organization               @relation(fields: [organizationId], references: [id])
  category           IngredientCategory?        @relation(fields: [categoryId], references: [id])
  vendorIngredients  VendorIngredient[]
  purchaseOrderLines PurchaseOrderLine[]
  costLogs           IngredientCostLog[]
  storageMappings    IngredientStorageMapping[]
  countLines         InventoryCountLine[]
}

model IngredientCostLog {
  id                   String   @id @default(cuid())
  ingredientId         String
  costPerReportingUnit Float
  source               String // PO_RECEIPT | MANUAL | IMPORT
  sourceRef            String?
  createdAt            DateTime @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
}

model IngredientDuplicateDismissal {
  id             String   @id @default(cuid())
  organizationId String
  ingredientAId  String
  ingredientBId  String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, ingredientAId, ingredientBId])
}

model InventoryCount {
  id                  String    @id @default(cuid())
  organizationId      String
  storeId             String
  name                String?
  notes               String?
  isPartial           Boolean   @default(false)
  startedAt           DateTime  @default(now())
  finalizedAt         DateTime?
  completedByUserIds  String[]
  sittingInventoryVal Float?
  status              String    @default("Draft") // Draft | Finalized

  organization Organization               @relation(fields: [organizationId], references: [id])
  store        Store                      @relation(fields: [storeId], references: [id])
  lines        InventoryCountLine[]
  corrections  InventoryCountCorrection[]
}

// One line per (storage area, ingredient) assignment, snapshotted when the draft
// is created — name/unit/cost frozen at count start so later price changes never
// rewrite a finalized count. quantityCounted null = not yet counted (distinct
// from an explicit 0 on the shelf).
model InventoryCountLine {
  id                   String    @id @default(cuid())
  inventoryCountId     String
  storageAreaId        String?
  ingredientId         String
  ingredientName       String
  reportingUnit        String
  quantityCounted      Float?
  costPerReportingUnit Float
  lineValue            Float?
  usageVariance        Float?
  sortOrder            Int       @default(0)
  countedAt            DateTime?

  inventoryCount InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  storageArea    StorageArea?   @relation(fields: [storageAreaId], references: [id])
  ingredient     Ingredient     @relation(fields: [ingredientId], references: [id])
}

// Audit trail for post-finalize corrections — one row per changed field. The
// count total is recomputed but the original entry stays explainable.
model InventoryCountCorrection {
  id        String   @id @default(cuid())
  countId   String
  lineId    String
  field     String // quantityCounted | costPerReportingUnit
  oldValue  Float?
  newValue  Float?
  note      String?
  userId    String
  createdAt DateTime @default(now())

  count InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
}

// ─── PHASE I-5: SALES CACHES (Square Orders → local aggregates) ──────────────
// Populated by the sales sync (SearchOrders, COMPLETED, closed_at). Dates and
// hours are bucketed in the STORE's timezone. Sync is idempotent per day: a
// re-sync replaces the covered days wholesale.

model SalesPeriodCache {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  date           DateTime @db.Date
  grossSales     Float    @default(0) // order totals incl. tax, after discounts
  netSales       Float    @default(0) // pre-tax: gross − tax
  taxTotal       Float    @default(0)
  discountTotal  Float    @default(0)
  orderCount     Int      @default(0)
  syncedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([organizationId, date])
}

// Per Square variation per day — feeds the Item Sales report now and
// theoretical usage / variance in I-6.
model SalesLineCache {
  id                String   @id @default(cuid())
  organizationId    String
  storeId           String
  date              DateTime @db.Date
  squareVariationId String
  quantitySold      Float    @default(0)
  grossSales        Float    @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, squareVariationId])
  @@index([storeId, date])
}

// Hourly pace — feeds the Dashboard (D-1) intraday chart.
model SalesHourlyCache {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  date           DateTime @db.Date
  hour           Int // 0–23, store-local
  netSales       Float    @default(0)
  orderCount     Int      @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date, hour])
  @@index([storeId, date])
}

// ─── PHASE D-1: DASHBOARD ─────────────────────────────────────────────────────

// Monthly sales goal per store (month = first-of-month UTC date). Managers and
// admins set it; the Dashboard's Monthly Goal card reads it.
model StoreMonthlyGoal {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  month          DateTime @db.Date
  goalAmount     Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, month])
}

// ─── PHASE 2: NUTRITION MODULE ────────────────────────────────────────────────

model MenuItem {
  id                 String   @id @default(cuid())
  organizationId     String
  squareCatalogObjId String?
  name               String
  description        String?
  category           String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id])
  nutrition    MenuItemNutrition?
  allergens    MenuItemAllergen[]
}

model MenuItemNutrition {
  id            String  @id @default(cuid())
  menuItemId    String  @unique
  servingSize   String?
  calories      Int?
  totalFatG     Float?
  saturatedFatG Float?
  transFatG     Float?
  cholesterolMg Float?
  sodiumMg      Float?
  totalCarbG    Float?
  dietaryFiberG Float?
  totalSugarsG  Float?
  addedSugarsG  Float?
  proteinG      Float?
  vitaminDMcg   Float?
  calciumMg     Float?
  ironMg        Float?
  potassiumMg   Float?

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model MenuItemAllergen {
  id         String @id @default(cuid())
  menuItemId String
  allergen   String

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, allergen])
}
